---
/**
 * Base HTML layout shared by all pages.
 * Loads fonts and global styles.
 */
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio de projectes d'infraestructura PACS clínica" } = Astro.props;
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — DSI · PACS</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-bg/82 backdrop-blur-md">
      <nav class="mx-auto flex max-w-[1200px] items-center justify-between px-10 py-4">
        <a
          href={import.meta.env.BASE_URL}
          class="flex items-center gap-2.5 text-amber -ml-3 px-3 py-1.5 rounded-full transition-shadow duration-300 hover:shadow-[0_0_20px_-4px_var(--color-amber)]"
        >
          <span class="w-2.5 h-2.5 rounded-full bg-amber shadow-[0_0_14px_-1px_var(--color-amber)]"></span>
          <span class="font-mono text-sm font-semibold tracking-[0.04em]">~/dsi-pacs</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a
            href="https://github.com/svroff/dosense-duke"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-amber transition-colors"
            aria-label="GitHub"
          >
            GitHub ↗
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border mt-20 py-8 text-center text-xs text-text-muted">
      <!-- Astro renders this at build time, so the year only updates on the next deploy. -->
      <p>Infraestructura PACS · Hospital Clínic de Barcelona · {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>
