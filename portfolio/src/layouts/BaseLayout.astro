---
/**
 * Base HTML layout shared by all pages.
 * Loads fonts and global styles.
 */
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio de projectes d'infraestructura PACS clínica" } = Astro.props;
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — PACS Portfolio</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={import.meta.env.BASE_URL} class="font-mono text-sm text-cyan hover:text-purple transition-colors">
          ~/pacs-portfolio
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href={import.meta.env.BASE_URL} class="text-text-muted hover:text-text transition-colors">Projectes</a>
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-text transition-colors"
            aria-label="GitHub"
          >
            GitHub ↗
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border mt-20 py-8 text-center text-xs text-text-muted">
      <p>Infraestructura PACS · Hospital Clínic de Barcelona · {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>
