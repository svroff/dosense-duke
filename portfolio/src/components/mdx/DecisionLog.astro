---
/**
 * Decision-log / Q&A component.
 * Each entry is its own bordered card, with the question prefixed by a
 * teal "P" (pregunta) and the answer by an amber "R" (resposta).
 */
interface Props {
  title: string;
  entries: { q: string; a: string }[];
}

const { title, entries } = Astro.props;
---

<div class="mb-2">
  <h4 class="font-mono text-sm text-text-muted flex items-center gap-2 mb-3">
    <span>📋</span> {title}
  </h4>
  <div class="flex flex-col gap-3">
    {entries.map((entry) => (
      <div class="border border-border rounded-[10px] bg-surface px-4.5 py-4">
        <div class="flex gap-2.5 mb-2">
          <span class="font-mono font-semibold text-teal flex-none">P</span>
          <span class="font-semibold">{entry.q}</span>
        </div>
        <div class="flex gap-2.5">
          <span class="font-mono font-semibold text-amber flex-none">R</span>
          <span class="text-text-muted">{entry.a}</span>
        </div>
      </div>
    ))}
  </div>
</div>
