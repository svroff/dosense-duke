---
/**
 * Home page — hero, portfolio-wide stats strip, and the project grid
 * (one featured card per project + a placeholder for what's next).
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import StatusBadge from "@components/mdx/StatusBadge.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
// Sort by dateUpdated descending
projects.sort((a, b) => b.data.dateUpdated.localeCompare(a.data.dateUpdated));

// Portfolio-wide stats — derived from the project collection itself, so they
// stay correct as projects are added instead of being hardcoded per-project
// numbers (those belong on each project's own page, not here).
const techCount = new Set(projects.flatMap((p) => p.data.techStack)).size;

const stats = [
  { value: String(projects.length), label: projects.length === 1 ? "projecte actiu" : "projectes actius" },
  { value: String(techCount), label: techCount === 1 ? "tecnologia documentada" : "tecnologies documentades" },
];
---

<BaseLayout title="Projectes">
  <div class="mx-auto max-w-[1200px] px-10 pt-20 pb-10">
    <!-- Hero -->
    <section class="max-w-[820px] mb-6">
      <div class="font-mono text-xs tracking-[0.16em] uppercase text-teal mb-5">
        Portfolio d'infraestructura · Hospital Clínic de Barcelona
      </div>
      <h1 class="font-display font-bold text-[58px] leading-[1.1] tracking-[-0.01em]">
        Projectes <span class="text-amber">DSI</span> - HCPB
      </h1>
      <p class="text-text-muted text-lg leading-relaxed mt-5">
        Projectes d'infraestructura d'imatge mèdica documentats de punta a punta. Cada projecte recull
        l'arquitectura, les decisions tècniques i els trade-offs perquè un altre sysadmin pugui aprendre
        com es va construir.
      </p>
    </section>

    <!-- Stats strip -->
    <section class="flex flex-wrap gap-3.5 my-9">
      {stats.map((stat) => (
        <div class="flex items-baseline gap-2.5 border border-border rounded-[10px] px-4.5 py-3 bg-surface2">
          <span class={`font-display font-bold text-2xl ${stat.accent ? "text-amber whitespace-nowrap" : "text-text"}`}>
            {stat.value}
          </span>
          <span class="font-mono text-[11px] tracking-[0.1em] uppercase text-text-muted">{stat.label}</span>
        </div>
      ))}
    </section>

    <!-- Project grid -->
    <section>
      <div class="font-mono text-[11px] tracking-[0.16em] uppercase text-text-muted mb-4">Projectes</div>
      <div class="grid gap-5 items-stretch" style="grid-template-columns: 1.6fr 1fr;">
        {projects.map((project) => (
          <a
            href={`${import.meta.env.BASE_URL}projects/${project.data.slug}`}
            class="pcard block rounded-2xl border border-border bg-surface2 p-[30px]"
          >
            <div class="flex items-start justify-between gap-4 mb-4">
              <h2 class="font-display font-semibold text-2xl text-text">{project.data.title}</h2>
              <StatusBadge status={project.data.status} />
            </div>
            <p class="text-text-muted text-base leading-relaxed mb-5.5">{project.data.summary}</p>
            <div class="flex flex-wrap gap-2">
              {project.data.techStack.map((tech) => (
                <span class="font-mono text-xs text-teal border border-border rounded-md px-2.5 py-1 bg-bg">
                  {tech}
                </span>
              ))}
            </div>
            <div class="mt-6 inline-flex items-center gap-2 font-mono text-[13px] text-amber">Veure projecte →</div>
          </a>
        ))}
        <div class="rounded-2xl border border-dashed border-border p-[30px] flex flex-col justify-center gap-2.5">
          <span class="font-mono text-xs tracking-[0.12em] uppercase text-text-muted">Espai per a futurs projectes</span>
          <p class="text-text-muted text-sm leading-relaxed">
            Cada nou desplegament d'infraestructura PACS s'afegeix aquí amb la seva pròpia fitxa i documentació.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
