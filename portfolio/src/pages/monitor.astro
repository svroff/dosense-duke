---
/**
 * Live deployment monitor — mostly decorative/static (the design's own
 * interactions note says these panels don't depend on state), except the
 * clock which needs a small client island.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Pipeline from "@components/Pipeline.astro";
import DiskUsage from "@components/mdx/DiskUsage.astro";
import Clock from "@components/islands/Clock.tsx";

const kpis = [
  { value: "200", label: "Estudis avui" },
  { value: "1.300", label: "Estudis / setmana" },
  { value: "~2", unit: "min", label: "Temps / sèrie", accent: true },
  { value: "6", label: "Estudis en cua" },
];

const containers = [
  { name: "dcm4chee", desc: "Receptor DICOM · :104", status: "RUNNING", statusColor: "green", stats: "CPU 4% · 1.2 GB" },
  { name: "Dosense", desc: "Motor d'anàlisi · METIS 2", status: "PROCESSANT", statusColor: "amber", stats: "CPU 71% · 38 GB" },
  { name: "MongoDB", desc: "Base de dades · :27017", status: "RUNNING", statusColor: "green", stats: "CPU 2% · 0.9 GB" },
];

const ports = [
  { port: "104", label: "DICOM", note: "ENTRADA", color: "amber", noteColor: "green" },
  { port: "27017", label: "MongoDB", note: "INTERN", color: "teal", noteColor: "muted" },
  { port: "—", label: "Sortida", note: "CAP · air-gapped", color: "muted", noteColor: "red" },
];

const logLines = [
  { time: "10:43:58", node: "mongodb", nodeColor: "teal", message: "resultats desats" },
  { time: "10:44:02", node: "cleanup", nodeColor: "red", message: "214 DICOM eliminats" },
  { time: "10:44:07", node: "ct", nodeColor: "amber", message: "C-STORE acceptat :104" },
  { time: "10:44:09", node: "dosense", nodeColor: "green", message: "sèrie detectada, processant", cursor: true },
];

const colorClass: Record<string, string> = { amber: "text-amber", teal: "text-teal", green: "text-green", red: "text-red", muted: "text-text-muted" };
---

<BaseLayout title="Monitor en viu">
  <div class="mx-auto max-w-[1200px] px-10 py-14 border-t border-border">
    <div class="border border-border rounded-[18px] p-[26px]">
      <!-- Top bar -->
      <div class="flex items-center justify-between pb-5 border-b border-border flex-wrap gap-3">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2.5">
            <span class="w-3 h-3 rounded-full bg-amber shadow-[0_0_16px_-1px_var(--color-amber)]"></span>
            <span class="font-mono font-semibold text-[19px] tracking-[0.06em]">DOSENSE</span>
          </div>
          <span class="font-mono text-[11px] text-text-muted border border-border rounded px-2 py-1">METIS 2</span>
          <span class="text-sm text-text-muted">HCPB · Hospital Clínic de Barcelona</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="inline-flex items-center gap-2 font-mono text-xs text-green border border-green/45 bg-green/12 rounded-full px-3 py-1.5">
            <span class="hb w-[7px] h-[7px] rounded-full bg-current"></span>OPERATIU
          </span>
          <Clock client:load />
        </div>
      </div>

      <!-- KPI row -->
      <div class="flex gap-4 mt-5.5">
        {kpis.map((kpi) => (
          <div class="flex-1 bg-surface border border-border rounded-xl px-5 py-4.5">
            <div class={`font-display font-bold text-[42px] leading-none ${kpi.accent ? "text-amber" : "text-text"}`}>
              {kpi.value}
              {kpi.unit && <span class="text-xl text-text-muted"> {kpi.unit}</span>}
            </div>
            <div class="font-mono text-[11px] tracking-[0.13em] uppercase text-text-muted mt-3">{kpi.label}</div>
          </div>
        ))}
      </div>

      <!-- Pipeline -->
      <div class="mt-4">
        <Pipeline
          eyebrow="Flux DICOM · temps real"
          eyebrowNote="comunicació per disc · un sol port d'entrada (:104)"
          stagger={0.7}
          nodes={[
            { label: "Modalitat CT", sublabel: "C-STORE :104", color: "amber" },
            { label: "dcm4chee", sublabel: "Receptor DICOM", color: "teal" },
            { label: "Volum compartit", sublabel: "/data/dicom_storage", color: "yellow" },
            { label: "Dosense", sublabel: "Anàlisi dosi + IQ + d'", color: "green" },
            { label: "MongoDB", sublabel: "Resultats :27017", color: "green" },
            { label: "Neteja", sublabel: "Eliminació DICOM", color: "red" },
            { label: "Exportació CSV", sublabel: "Manual → EuroSafe", color: "teal" },
          ]}
        />
      </div>

      <!-- Bottom 3 columns -->
      <div class="grid grid-cols-3 gap-4 mt-4">
        <!-- Containers -->
        <div class="bg-surface border border-border rounded-xl p-5">
          <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-text-muted mb-1.5">Contenidors</div>
          {containers.map((c, i) => (
            <div class={`flex items-center gap-3 py-3.5 ${i < containers.length - 1 ? "border-b border-border" : ""}`}>
              <span class={`hb w-2 h-2 rounded-full flex-none bg-current ${colorClass[c.statusColor]}`}></span>
              <div class="flex-1">
                <div class="font-display font-semibold text-sm">{c.name}</div>
                <div class="font-mono text-[11px] text-text-muted">{c.desc}</div>
              </div>
              <div class="text-right font-mono text-[11px] text-text-muted">
                <div class={colorClass[c.statusColor]}>{c.status}</div>
                <div>{c.stats}</div>
              </div>
            </div>
          ))}
          <div class="mt-3.5 pt-3.5 border-t border-border flex flex-wrap gap-2 font-mono text-[11px]">
            <span class="text-text-muted border border-border rounded px-2 py-1">6 vCPU</span>
            <span class="text-text-muted border border-border rounded px-2 py-1">64 GB RAM</span>
            <span class="text-text-muted border border-border rounded px-2 py-1">SLES (SUSE)</span>
          </div>
        </div>

        <!-- Disks -->
        <div class="bg-surface border border-border rounded-xl p-5">
          <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-text-muted mb-4">Discos · 4 punts de muntatge</div>
          <DiskUsage
            variant="compact"
            disks={[
              { label: "Sistema", note: "38 / 120 GB", percent: 32, color: "green" },
              { label: "Dades", note: "402 / 600 GB", percent: 67, color: "amber", risk: "risc #1" },
              { label: "BBDD (MongoDB)", note: "3.2 / 80 GB", percent: 4, color: "teal" },
              { label: "Logs", note: "0.3 / 20 GB", percent: 2, color: "green" },
            ]}
          />
          <div class="mt-4 font-mono text-[10.5px] text-text-muted leading-relaxed">
            El buffer d'entrada creix fins omplir el disc si el processament s'encalla · rotació de logs a 7 dies.
          </div>
        </div>

        <!-- Ports + Log -->
        <div class="flex flex-col gap-4">
          <div class="bg-surface border border-border rounded-xl p-5">
            <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-text-muted mb-3">Mapa de ports</div>
            {ports.map((p) => (
              <div class="flex items-center gap-2.5 py-2 font-mono text-xs">
                <span class={`w-[52px] ${colorClass[p.color]}`}>{p.port}</span>
                <span class="flex-1 text-text">{p.label}</span>
                <span class={colorClass[p.noteColor]}>{p.note}</span>
              </div>
            ))}
          </div>
          <div class="bg-surface2 border border-border rounded-xl p-4 flex-1">
            <div class="flex items-center gap-2 mb-2.5">
              <span class="hb w-[7px] h-[7px] rounded-full bg-green"></span>
              <span class="font-mono text-[11px] text-text-muted">consola de log</span>
            </div>
            <div class="font-mono text-[11px] leading-[1.95]">
              {logLines.map((line) => (
                <div>
                  <span class="text-text-muted">{line.time}</span>{" "}
                  <span class={colorClass[line.nodeColor]}>{line.node}</span>{" "}
                  <span class="text-text">
                    {line.message}
                    {line.cursor && <span class="cursor text-amber">▍</span>}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
